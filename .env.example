# ============================================
# 认知智能体系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env.local 并填入你的配置

# ========== LLM API 配置 (必需) ==========
# 认知智能体需要 LLM 来理解和决策
# 使用豆包/火山引擎 ARK API
ARK_API_KEY=your-ark-api-key-here

# 或者使用其他兼容的 LLM 服务
# 参考 coze-coding-dev-sdk 文档配置

# ========== Supabase 数据库配置 (可选) ==========
# 用于数据持久化，不配置也能运行基本功能
# 从 Supabase Dashboard → Settings → API 获取
# COZE_SUPABASE_URL=https://your-project-id.supabase.co
# COZE_SUPABASE_ANON_KEY=your-anon-key-here

# PostgreSQL 直连 URL (可选)
# PGDATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ========== S3 对象存储配置 (可选) ==========
# 用于文件存储功能
# COZE_BUCKET_ENDPOINT_URL=https://your-bucket-endpoint.com
# COZE_BUCKET_NAME=your-bucket-name
