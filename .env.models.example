# ═══════════════════════════════════════════════════════════════════════
# 多模型网关配置示例
# ═══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────
# 1. Coze SDK（主模型 - 需要积分）
# ─────────────────────────────────────────────────────────────────────
# 已自动注入，无需配置
# COZE_WORKLOAD_IDENTITY_API_KEY=xxx

# ─────────────────────────────────────────────────────────────────────
# 2. Ollama 本地模型（完全免费 - 推荐作为备份）
# ─────────────────────────────────────────────────────────────────────
# 安装 Ollama: https://ollama.ai
# 下载模型: ollama pull llama3.2
# 启动服务: ollama serve（默认运行在 11434 端口）

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ─────────────────────────────────────────────────────────────────────
# 3. OpenAI 兼容 API（可选 - DeepSeek/Moonshot/通义千问等）
# ─────────────────────────────────────────────────────────────────────

# DeepSeek（便宜好用）
# OPENAI_COMPATIBLE_ENABLED=true
# OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com/v1
# OPENAI_COMPATIBLE_API_KEY=sk-xxx
# OPENAI_COMPATIBLE_MODEL=deepseek-chat

# Moonshot（Kimi）
# OPENAI_COMPATIBLE_ENABLED=true
# OPENAI_COMPATIBLE_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_COMPATIBLE_API_KEY=sk-xxx
# OPENAI_COMPATIBLE_MODEL=moonshot-v1-8k

# 通义千问（阿里云）
# OPENAI_COMPATIBLE_ENABLED=true
# OPENAI_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_COMPATIBLE_API_KEY=sk-xxx
# OPENAI_COMPATIBLE_MODEL=qwen-turbo

# ─────────────────────────────────────────────────────────────────────
# 4. 网关配置
# ─────────────────────────────────────────────────────────────────────

# 调用次数预警阈值
GATEWAY_WARNING_THRESHOLD=100

# 是否自动切换模型（主模型失败时自动使用备份）
GATEWAY_AUTO_SWITCH=true

# 是否启用缓存
GATEWAY_ENABLE_CACHE=true
