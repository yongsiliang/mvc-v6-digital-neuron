{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zi-agent",
  "version": "0.1.0",
  "identifier": "com.zi.agent",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "紫 - 自主智能体",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "shortDescription": "紫 - 自主智能体",
    "longDescription": "紫 - 自主智能体，能思考更能行动",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "open-app",
          "cmd": "",
          "args": true
        }
      ]
    }
  }
}
